# ─── Database ────────────────────────────────────────────
# For development (direct connection):
DATABASE_URL="postgresql://comunet:comunet_dev_2024@localhost:5432/comunet?schema=public"
# For production with PgBouncer (connection pooling):
# DATABASE_URL="postgresql://comunet:PROD_PASSWORD@localhost:6432/comunet?schema=public&connection_limit=20&pool_timeout=10"

# Direct connection for Prisma CLI (migrations, studio).
# Required when using PgBouncer, because PgBouncer in transaction mode
# is incompatible with prepared statements used by Prisma CLI.
# DIRECT_DATABASE_URL="postgresql://comunet:PROD_PASSWORD@localhost:5432/comunet?schema=public"

# ─── Auth ────────────────────────────────────────────────
# IMPORTANT: In production, AUTH_SECRET is MANDATORY. The app will crash
# on startup if it's not set. Generate one with: openssl rand -base64 32
AUTH_SECRET="comunet-dev-secret-change-in-production-min-32-chars"

# ─── Cache Driver ────────────────────────────────────────
# Controls the backend for rate limiting, JWT blocklist, and future caches.
# Options: "memory" | "upstash" | "redis"
#   memory  → in-process Map (single-instance only, dev default)
#   upstash → HTTP/REST client for Upstash Redis (serverless)
#   redis   → TCP client (ioredis) for self-hosted Redis/Valkey
CACHE_DRIVER="memory"

# Only if CACHE_DRIVER=redis (e.g. NAS, local Docker)
# REDIS_URL="redis://redis:6379"

# Only if CACHE_DRIVER=upstash
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── App ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_VERSION="0.1.0"

# ─── Storage ─────────────────────────────────────────────
# Options: "local" | "s3"
STORAGE_ADAPTER="local"
STORAGE_PATH="./uploads"

# S3-compatible storage (only when STORAGE_ADAPTER=s3)
# Works with AWS S3, MinIO, Cloudflare R2, DigitalOcean Spaces
# S3_BUCKET="comunet-documents"
# S3_REGION="eu-west-1"
# S3_ENDPOINT="http://localhost:9000"  # MinIO endpoint (omit for AWS S3)
# S3_PUBLIC_URL="" # Public IP/Domain for downloads. Leave empty to use S3_ENDPOINT
# S3_PREFIX="documents"
# AWS_ACCESS_KEY_ID="your-access-key"
# AWS_SECRET_ACCESS_KEY="your-secret-key"

# ─── Email (Resend) ───────────────────────────────────────
# Crea tu cuenta gratuita en https://resend.com
# Sin esta clave, los emails se registran en consola (mock mode)
RESEND_API_KEY=""
RESEND_FROM="COMUNET <noreply@tudominio.com>"
