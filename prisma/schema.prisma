generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────────

enum UserRole {
  SUPERADMIN
  OFFICE_ADMIN
  MANAGER
  ACCOUNTANT
  PRESIDENT
  OWNER
  PROVIDER
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum UnitType {
  APARTMENT
  COMMERCIAL
  GARAGE
  STORAGE
  OTHER
}

enum BudgetStatus {
  DRAFT
  APPROVED
  CLOSED
}

enum FeeFrequency {
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
}

enum ReceiptStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  RETURNED
  CANCELLED
}

enum PaymentMethod {
  BANK_TRANSFER
  DIRECT_DEBIT
  CASH
  CHECK
  OTHER
}

enum DebtStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  WRITTEN_OFF
}

enum IncidentPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum IncidentStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  WAITING_VENDOR
  RESOLVED
  CLOSED
}

enum CommentVisibility {
  INTERNAL
  SHARED
}

enum MeetingType {
  ORDINARY
  EXTRAORDINARY
}

enum MeetingStatus {
  DRAFT
  SCHEDULED
  HELD
  CLOSED
}

enum MinuteStatus {
  DRAFT
  GENERATED
  APPROVED
}

enum AttendanceType {
  IN_PERSON
  DELEGATED
  REMOTE
}

enum VoteValue {
  FOR
  AGAINST
  ABSTAIN
}

enum DocumentVisibility {
  INTERNAL
  OWNERS
  PUBLIC
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum NotificationStatus {
  PENDING
  SENT
  READ
  FAILED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  ARCHIVE
  STATUS_CHANGE
  LOGIN
  LOGOUT
}

// ─── MODELS ─────────────────────────────────────────────

model Office {
  id         String    @id @default(cuid())
  name       String
  slug       String    @unique
  nif        String
  email      String
  phone      String?
  address    String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  users         User[]
  communities   Community[]
  owners        Owner[]
  tenants       Tenant[]
  providers     Provider[]
  notifications Notification[]
  auditLogs     AuditLog[]

  @@map("offices")
}

model User {
  id               String     @id @default(cuid())
  officeId         String
  name             String
  email            String     @unique
  passwordHash     String
  role             UserRole
  status           UserStatus @default(ACTIVE)
  linkedOwnerId    String?
  linkedProviderId String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  archivedAt       DateTime?

  office           Office            @relation(fields: [officeId], references: [id])
  linkedOwner      Owner?            @relation(fields: [linkedOwnerId], references: [id])
  linkedProvider   Provider?         @relation(fields: [linkedProviderId], references: [id])
  incidents        Incident[]        @relation("IncidentCreator")
  incidentComments IncidentComment[]
  documents        Document[]
  notifications    Notification[]    @relation("NotificationRecipient")

  @@index([officeId])
  @@index([email])
  @@index([role])
  @@map("users")
}

model Community {
  id         String    @id @default(cuid())
  officeId   String
  name       String
  cif        String?
  address    String?
  iban       String?
  fiscalYear Int       @default(2024)
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  office         Office          @relation(fields: [officeId], references: [id])
  buildings      Building[]
  units          Unit[]
  boardPositions BoardPosition[]
  budgets        Budget[]
  feeRules       FeeRule[]
  receipts       Receipt[]
  debts          Debt[]
  incidents      Incident[]
  meetings       Meeting[]
  documents      Document[]
  notifications  Notification[]

  @@index([officeId])
  @@map("communities")
}

model Building {
  id          String   @id @default(cuid())
  communityId String
  name        String
  code        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  community Community @relation(fields: [communityId], references: [id])
  units     Unit[]

  @@index([communityId])
  @@map("buildings")
}

model Unit {
  id          String   @id @default(cuid())
  communityId String
  buildingId  String?
  reference   String
  type        UnitType @default(APARTMENT)
  floor       String?
  door        String?
  areaM2      Float?
  coefficient Float  @default(1.0)
  quotaPercent Float @default(0.0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  community   Community    @relation(fields: [communityId], references: [id])
  building    Building?    @relation(fields: [buildingId], references: [id])
  ownerships  Ownership[]
  receipts    Receipt[]
  debts       Debt[]
  incidents   Incident[]
  attendances Attendance[]
  votes       Vote[]

  @@unique([communityId, reference])
  @@index([communityId])
  @@index([buildingId])
  @@map("units")
}

model Owner {
  id         String    @id @default(cuid())
  officeId   String
  fullName   String
  dni        String?
  email      String?
  phone      String?
  address    String?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  office         Office          @relation(fields: [officeId], references: [id])
  ownerships     Ownership[]
  boardPositions BoardPosition[]
  receipts       Receipt[]
  debts          Debt[]
  attendances    Attendance[]
  votes          Vote[]
  users          User[]

  @@index([officeId])
  @@map("owners")
}

model Tenant {
  id         String    @id @default(cuid())
  officeId   String
  fullName   String
  dni        String?
  email      String?
  phone      String?
  address    String?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  office Office @relation(fields: [officeId], references: [id])

  @@index([officeId])
  @@map("tenants")
}

model Ownership {
  id                    String    @id @default(cuid())
  unitId                String
  ownerId               String
  ownershipPercent      Float   @default(100)
  isPrimaryBillingContact Boolean @default(false)
  startDate             DateTime  @default(now())
  endDate               DateTime?

  unit  Unit  @relation(fields: [unitId], references: [id])
  owner Owner @relation(fields: [ownerId], references: [id])

  @@index([unitId])
  @@index([ownerId])
  @@index([ownerId, endDate])  // Portal: active ownerships lookup
  @@map("ownerships")
}

model BoardPosition {
  id          String    @id @default(cuid())
  communityId String
  ownerId     String
  role        String    // PRESIDENT, VICE_PRESIDENT, SECRETARY, TREASURER, MEMBER
  startDate   DateTime  @default(now())
  endDate     DateTime?

  community Community @relation(fields: [communityId], references: [id])
  owner     Owner     @relation(fields: [ownerId], references: [id])

  @@index([communityId])
  @@index([ownerId])
  @@map("board_positions")
}

model Provider {
  id         String    @id @default(cuid())
  officeId   String
  name       String
  cif        String?
  email      String?
  phone      String?
  category   String?
  address    String?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  office    Office     @relation(fields: [officeId], references: [id])
  incidents Incident[]
  users     User[]

  @@index([officeId])
  @@map("providers")
}

model Budget {
  id          String       @id @default(cuid())
  communityId String
  year        Int
  totalAmount Float      @default(0)
  status      BudgetStatus @default(DRAFT)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  community Community    @relation(fields: [communityId], references: [id])
  lines     BudgetLine[]

  @@unique([communityId, year])
  @@index([communityId])
  @@map("budgets")
}

model BudgetLine {
  id          String   @id @default(cuid())
  budgetId    String
  concept     String
  category    String?
  amount      Float  @default(0)
  periodicity String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  budget Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([budgetId])
  @@map("budget_lines")
}

model FeeRule {
  id              String       @id @default(cuid())
  communityId     String
  name            String
  frequency       FeeFrequency @default(MONTHLY)
  startDate       DateTime     @default(now())
  calculationBase String?      // 'COEFFICIENT', 'QUOTA_PERCENT', 'FIXED'
  fixedAmount     Float?
  notes           String?
  active          Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  community Community @relation(fields: [communityId], references: [id])

  @@index([communityId])
  @@map("fee_rules")
}

model Receipt {
  id          String        @id @default(cuid())
  communityId String
  unitId      String
  ownerId     String
  periodStart DateTime
  periodEnd   DateTime
  issueDate   DateTime      @default(now())
  dueDate     DateTime
  amount      Float
  paidAmount  Float       @default(0)
  status      ReceiptStatus @default(DRAFT)
  reference   String        @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  community Community @relation(fields: [communityId], references: [id])
  unit      Unit      @relation(fields: [unitId], references: [id])
  owner     Owner     @relation(fields: [ownerId], references: [id])
  payments  Payment[]
  debts     Debt[]

  @@index([communityId])
  @@index([unitId])
  @@index([ownerId])
  @@index([status])
  @@index([dueDate])
  @@index([ownerId, communityId])  // Portal: owner receipts by community
  @@map("receipts")
}

model Payment {
  id          String        @id @default(cuid())
  receiptId   String
  paymentDate DateTime      @default(now())
  amount      Float
  method      PaymentMethod @default(BANK_TRANSFER)
  reference   String?
  notes       String?
  createdAt   DateTime      @default(now())

  receipt Receipt @relation(fields: [receiptId], references: [id])

  @@index([receiptId])
  @@map("payments")
}

model Debt {
  id          String     @id @default(cuid())
  communityId String
  unitId      String
  ownerId     String
  receiptId   String?
  principal   Float
  surcharge   Float    @default(0)
  status      DebtStatus @default(PENDING)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  community Community @relation(fields: [communityId], references: [id])
  unit      Unit      @relation(fields: [unitId], references: [id])
  owner     Owner     @relation(fields: [ownerId], references: [id])
  receipt   Receipt?  @relation(fields: [receiptId], references: [id])

  @@index([communityId])
  @@index([ownerId])
  @@index([status])
  @@index([communityId, status])  // Reports: debt aggregation by community
  @@index([ownerId, status])      // Portal: owner pending debts
  @@map("debts")
}

model Incident {
  id                 String           @id @default(cuid())
  communityId        String
  unitId             String?
  createdByUserId    String
  assignedProviderId String?
  title              String
  description        String?
  priority           IncidentPriority @default(MEDIUM)
  status             IncidentStatus   @default(OPEN)
  reportedAt         DateTime         @default(now())
  dueAt              DateTime?
  resolvedAt         DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  community        Community         @relation(fields: [communityId], references: [id])
  unit             Unit?             @relation(fields: [unitId], references: [id])
  createdBy        User              @relation("IncidentCreator", fields: [createdByUserId], references: [id])
  assignedProvider Provider?         @relation(fields: [assignedProviderId], references: [id])
  comments         IncidentComment[]

  @@index([communityId])
  @@index([status])
  @@index([assignedProviderId])
  @@index([createdByUserId])
  @@map("incidents")
}

model IncidentComment {
  id           String            @id @default(cuid())
  incidentId   String
  authorUserId String
  body         String
  visibility   CommentVisibility @default(INTERNAL)
  createdAt    DateTime          @default(now())

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  author   User     @relation(fields: [authorUserId], references: [id])

  @@index([incidentId])
  @@map("incident_comments")
}

model Meeting {
  id          String        @id @default(cuid())
  communityId String
  title       String
  meetingType MeetingType   @default(ORDINARY)
  scheduledAt DateTime
  location    String?
  description String?
  status      MeetingStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  community   Community    @relation(fields: [communityId], references: [id])
  agendaItems AgendaItem[]
  attendances Attendance[]
  minutes     Minute[]

  @@index([communityId])
  @@index([scheduledAt])
  @@map("meetings")
}

model AgendaItem {
  id          String @id @default(cuid())
  meetingId   String
  sortOrder   Int    @default(0)
  title       String
  description String?

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  votes   Vote[]

  @@index([meetingId])
  @@map("agenda_items")
}

model Attendance {
  id                String         @id @default(cuid())
  meetingId         String
  ownerId           String?
  unitId            String?
  attendeeName      String
  coefficientPresent Float       @default(0)
  attendanceType    AttendanceType @default(IN_PERSON)

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  owner   Owner?  @relation(fields: [ownerId], references: [id])
  unit    Unit?   @relation(fields: [unitId], references: [id])

  @@index([meetingId])
  @@map("attendances")
}

model Vote {
  id               String    @id @default(cuid())
  agendaItemId     String
  ownerId          String?
  unitId           String?
  vote             VoteValue @default(ABSTAIN)
  coefficientWeight Float  @default(0)

  agendaItem AgendaItem @relation(fields: [agendaItemId], references: [id], onDelete: Cascade)
  owner      Owner?     @relation(fields: [ownerId], references: [id])
  unit       Unit?      @relation(fields: [unitId], references: [id])

  @@index([agendaItemId])
  @@map("votes")
}

model Minute {
  id         String       @id @default(cuid())
  meetingId  String
  content    String?
  status     MinuteStatus @default(DRAFT)
  createdAt  DateTime     @default(now())
  approvedAt DateTime?

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@map("minutes")
}

model Document {
  id               String             @id @default(cuid())
  communityId      String
  category         String?
  title            String
  storagePath      String
  mimeType         String?
  size             Int                @default(0)
  visibility       DocumentVisibility @default(INTERNAL)
  uploadedByUserId String
  createdAt        DateTime           @default(now())
  archivedAt       DateTime?

  community  Community @relation(fields: [communityId], references: [id])
  uploadedBy User      @relation(fields: [uploadedByUserId], references: [id])

  @@index([communityId])
  @@index([visibility])
  @@map("documents")
}

model Notification {
  id              String             @id @default(cuid())
  officeId        String
  communityId     String?
  recipientUserId String?
  channel         NotificationChannel @default(IN_APP)
  title           String
  body            String?
  status          NotificationStatus  @default(PENDING)
  createdAt       DateTime           @default(now())
  sentAt          DateTime?

  office    Office     @relation(fields: [officeId], references: [id])
  community Community? @relation(fields: [communityId], references: [id])
  recipient User?      @relation("NotificationRecipient", fields: [recipientUserId], references: [id])

  @@index([officeId])
  @@index([recipientUserId])
  @@index([status])
  @@map("notifications")
}

model AuditLog {
  id         String      @id @default(cuid())
  officeId   String
  userId     String
  entityType String
  entityId   String
  action     AuditAction
  metaJson   String?     // JSON string with additional metadata
  createdAt  DateTime    @default(now())

  office Office @relation(fields: [officeId], references: [id])

  @@index([officeId])
  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}
